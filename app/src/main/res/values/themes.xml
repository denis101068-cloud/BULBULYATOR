    <!-- Бело-золотая тема -->
    <style name="Theme.BULBULYATOR.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#FFD700</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1A1A1A</item>
        <item name="android:windowBackground">#F5F5F0</item>
        <item name="android:statusBarColor">#1A1A1A</item>
    </style>

    <!-- Круглая аватарка -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>
