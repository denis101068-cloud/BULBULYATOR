<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Хедер -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        android:orientation="horizontal"
        android:padding="15dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#8249;"
            android:textColor="#FFD700"
            android:textSize="32sp"
            android:clickable="true"
            android:padding="5dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Настройки"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="10dp" />
    </LinearLayout>

    <!-- Контент -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">

            <!-- Тема -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/themeSectionLabel"
                android:text="Оформление"
                android:textSize="13sp"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp" />

            <androidx.cardview.widget.CardView
                android:id="@+id/themeCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Чёрно-золотой -->
                    <LinearLayout
                        android:id="@+id/themeDarkOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- Превью -->
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="32dp"
                            android:background="#121212"
                            android:orientation="horizontal"
                            android:layout_marginEnd="14dp">
                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="#1E1E1E" />
                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="#FFD700" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/themeDarkLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Чёрно-золотой"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/themeDarkDesc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Тёмный фон, золотые акценты"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/themeDarkCheck"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#10003;"
                            android:textColor="#FFD700"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:visibility="visible" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:id="@+id/themeDivider" />

                    <!-- Бело-золотой -->
                    <LinearLayout
                        android:id="@+id/themeLightOption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- Превью -->
                        <LinearLayout
                            android:layout_width="48dp"
                            android:layout_height="32dp"
                            android:background="#F5F5F0"
                            android:orientation="horizontal"
                            android:layout_marginEnd="14dp">
                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="#FFFFFF" />
                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="#FFD700" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/themeLightLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Бело-золотой"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/themeLightDesc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Светлый фон, золотые акценты"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/themeLightCheck"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#10003;"
                            android:textColor="#FFD700"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:visibility="gone" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
